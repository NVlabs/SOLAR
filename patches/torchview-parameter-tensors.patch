+    def _render_parameter_nodes(self) -> None:
+        '''Find parameter-tensor TensorNodes that are parents of visited
+        FunctionNodes but weren't reached by the hierarchy traversal.
+        Add them as nodes and create edges param -> func.'''
+        # Collect all FunctionNodes/ModuleNodes that were visited
+        visited_compute_nodes: set[int] = set()
+        compute_node_list: list[COMPUTATION_NODES] = []
+        for tail, head in self.edge_list:
+            for n in (tail, head):
+                if isinstance(n, (FunctionNode, ModuleNode)) and id(n) not in visited_compute_nodes:
+                    visited_compute_nodes.add(id(n))
+                    compute_node_list.append(n)
+
+        for compute_node in compute_node_list:
+            for parent in compute_node.parents:
+                if (
+                    isinstance(parent, TensorNode)
+                    and getattr(parent, 'is_param', False)
+                    and id(parent) not in self.node_set
+                ):
+                    self.add_node(parent, self.visual_graph)
+                    self.edge_list.append((parent, compute_node))
 
