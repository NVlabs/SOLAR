+def _flatten_args(args: Any) -> list[Any]:
+    """Flatten nested args (tuples/lists) into a flat list of leaf values."""
+    result: list[Any] = []
+    if isinstance(args, (tuple, list)):
+        for item in args:
+            result.extend(_flatten_args(item))
+    else:
+        result.append(args)
+    return result
